# 0x API (Node/examples)
ZEROX_API_KEY=
ZEROX_API_BASE_URL=https://api.0x.org

# 0x API (Vite frontend)
VITE_ZEROX_API_KEY=
VITE_ZEROX_API_BASE_URL=/api/0x
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: OpenAI for LLM intent parsing. If omitted, a deterministic parser is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4.1-mini

# Wallet execution examples
PRIVATE_KEY=
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_URL_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional Vite RPC overrides for wagmi
VITE_RPC_URL_MAINNET=
VITE_RPC_URL_BASE=
VITE_RPC_URL_ARBITRUM=
VITE_RPC_URL_OPTIMISM=
VITE_RPC_URL_POLYGON=

# Optional account for quote previews
DEMO_WALLET_ADDRESS=0x1111111111111111111111111111111111111111
VITE_DEMO_WALLET_ADDRESS=0x1111111111111111111111111111111111111111
